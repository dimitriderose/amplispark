graph TB
    subgraph Browser["User Browser (React 19 + TypeScript)"]
        FE["Frontend<br/>React 19 + TypeScript<br/>Vite 7<br/>React Router"]
        AUTH["Firebase Google Auth<br/>signInWithPopup<br/>ID Token → Bearer Header<br/>Account Dropdown"]
        PAGES["Pages<br/>Landing (marketing)<br/>Brands (paginated list)<br/>Dashboard / Generate<br/>Post History<br/>Export / Edit Brand"]
        WIZARD["Onboard Wizard<br/>OnboardWizard.tsx (732 lines)<br/>3-Step Deferred Creation<br/>useWizardState.ts<br/>sessionStorage persistence<br/>2-min timeout safety"]
        TOUR["Guided Tour<br/>GuidedTour.tsx (436 lines)<br/>11-Step SVG Spotlight<br/>useTour.ts<br/>data-tour-id targeting<br/>Per-brand localStorage"]
        FE_HOOKS["Shared Hooks & Types<br/>useFetch&lt;T&gt; · useIsMobile · useIsTablet<br/>types/index.ts · types/api.ts<br/>constants/statusMaps.ts<br/>utils/downloads.ts<br/>ui/PageContainer · ErrorBanner · Spinner"]
    end

    subgraph CloudRun["Google Cloud Run"]
        subgraph AppSetup["server.py (~65 lines)"]
            APP["FastAPI App<br/>CORS · Router Includes<br/>SPA Catch-All<br/>(path traversal prevention)"]
        end

        subgraph Middleware["Auth & Logging Middleware Layer"]
            MW["middleware.py<br/>verify_firebase_token()<br/>firebase_admin.verify_id_token()<br/>verify_brand_owner()<br/>Depends() on HTTP routers<br/>verify_ws_brand_owner()<br/>Sec-WebSocket-Protocol auth<br/>HMAC OAuth State<br/>for WebSocket endpoints"]
            MWL["RequestContextMiddleware<br/>middleware_logging.py<br/>request_id · user_uid<br/>duration_ms · JSON logs"]
        end

        subgraph Routers["FastAPI Routers (7 modules)"]
            R_BRANDS["brands.py<br/>/api/brands/*"]
            R_PLANS["plans.py<br/>/api/plans/*"]
            R_POSTS["posts.py<br/>/api/posts/*"]
            R_GEN["generation.py<br/>/api/generate/*<br/>SSE Stream"]
            R_MEDIA["media.py<br/>/api/storage/*<br/>/api/export/*"]
            R_INT["integrations.py<br/>/api/brands/*/integrations/*<br/>Notion OAuth · Email · .ics"]
            R_VOICE["voice.py<br/>/api/voice/*<br/>WebSocket Proxy<br/>Sec-WebSocket-Protocol Auth"]
        end

        subgraph Pipeline["ADK Sequential Pipeline"]
            BA["Brand Analyst Agent<br/>URL Scraping + Brand DNA<br/>Colors, Tone, Audience<br/>Temperature 0.15"]
            STR["Strategy Agent<br/>Multi-Platform Calendar<br/>AI-Researched Frequency<br/>Google Search Grounding<br/>Pillar-Based Planning<br/>Social Proof Tiers"]
            CC["Content Creator Agent<br/>(Orchestrator)"]
            RA["Review Agent<br/>Multiplicative Two-Step Scoring<br/>LLM → engagement_scores +<br/>structural_issues →<br/>code computes score"]
        end

        subgraph CCModules["Content Creator Sub-Modules"]
            CP["caption_pipeline.py<br/>Caption Generation"]
            CB["carousel_builder.py<br/>7-Slide Parallel Gen"]
            HE["hashtag_engine.py<br/>Sanitization · Limits"]
            QG["quality_gates.py<br/>Pre/Post Quality Checks"]
            IPB["image_prompt_builder.py<br/>Platform-Aware Prompts"]
        end

        subgraph Scoring["Scoring Computation"]
            SC["Score = content_quality ×<br/>structural_modifier<br/>Platform-specific weights<br/>(15 profiles: 11 platforms +<br/>4 derivative overrides)<br/>Structural floor: 0.60–0.92"]
        end

        subgraph Support["Supporting Agents"]
            VC["Voice Coach<br/>Gemini Live API<br/>BidiGenerateContent<br/>Tier-Aware Strategy +<br/>Calendar Context<br/>(plan_id → days, scores, trends)"]
            VID["Video Creator<br/>Veo 3.1<br/>Reels / TikTok Clips"]
        end

        subgraph Shared["Shared Modules"]
            CL["clients.py<br/>Singleton Gemini Client"]
            GU["gcs_utils.py<br/>GCS URI Parsing"]
            CO["constants.py<br/>PILLARS · DERIVATIVE_TYPES<br/>PLATFORM_STRENGTHS<br/>PILLAR_DESCRIPTIONS<br/>PILLAR_NARRATIVES<br/>Scoring Weights"]
        end

        subgraph Services["Backend Services"]
            WS["Web Scraper<br/>httpx + BeautifulSoup"]
            BT["Brand Tools<br/>ADK Tool Wrappers"]
            HS["Hashtag Sanitizer<br/>Stopword Filter<br/>Per-Platform Limits"]
            EX["Export Service<br/>ZIP + Notion + .ics<br/>Direct GCS Download"]
            IF["Image Fallback<br/>Separate Image-Only Gen<br/>On Interleaved Failure"]
            PR["Platform Registry<br/>platforms.py<br/>11 Platforms + 4 Derivative Overrides<br/>PlatformSpec + Scoring Weights"]
            BA_SVC["Brand Assets Service<br/>brand_assets.py<br/>Logo + Product Photo Cache"]
            NC["Notion Client<br/>notion_client.py<br/>Mandatory Fernet Encryption<br/>HMAC OAuth State<br/>Database Export"]
            EC["Email Client<br/>email_client.py<br/>Resend API / .ics Delivery"]
            BTS["Budget Tracker<br/>Firestore-Persisted<br/>budget_tracker.py"]
        end
    end

    subgraph CICD["CI/CD Pipeline"]
        DS["deploy.sh<br/>One-Command Deploy<br/>Reads .env Config"]
        CBuild["Cloud Build<br/>cloudbuild.yaml<br/>4-Step Pipeline"]
        AR["Artifact Registry<br/>Docker Images<br/>amplifi:latest"]
        TF["Terraform IaC<br/>main.tf<br/>GCP Resource Provisioning"]
    end

    subgraph Testing["Testing (pytest)"]
        TCONF["conftest.py<br/>Fixtures"]
        T_MW["test_middleware.py<br/>12 Tests"]
        T_INT["test_integrations.py<br/>6 Tests"]
        T_BT["test_budget_tracker.py<br/>12 Tests"]
        T_BR["test_brands.py<br/>2 Tests"]
        T_PO["test_posts.py<br/>3 Tests"]
    end

    subgraph GCP["Google Cloud Platform"]
        FS[("Cloud Firestore<br/>Brand Profiles (owner_uid)<br/>Content Plans + Posts<br/>Video Jobs<br/>Frequency Cache (7-day TTL)")]
        GCS[("Cloud Storage<br/>Generated Images<br/>Generated Videos<br/>Uploaded Assets")]
        FA["Firebase Auth<br/>Google Sign-In Provider<br/>Persistent UIDs<br/>ID Token Verification"]
    end

    subgraph Gemini["Google Gemini API"]
        GFlash["gemini-3-flash-preview (text)<br/>gemini-3.1-flash-image-preview (image)<br/>generateContent"]
        GLive["Gemini Live API<br/>BidiGenerateContent<br/>Multi-Turn Voice"]
    end

    %% Browser to backend
    FE <-->|"REST + SSE<br/>/api/*<br/>Authorization: Bearer token"| APP
    AUTH <-->|"Google Sign-In<br/>UID + ID Token"| FA
    FE --- PAGES
    FE --- WIZARD
    FE --- TOUR
    FE --- FE_HOOKS
    WIZARD -->|"createBrand → updateBrand<br/>uploadBrandAsset → setBrandLogo<br/>→ analyzeBrand"| APP
    TOUR -->|"data-tour-id targeting<br/>dashboard elements"| PAGES

    %% App → Middleware → Routers
    APP --> MWL
    MWL --> MW
    APP --> MW
    MW --> R_BRANDS
    MW --> R_PLANS
    MW --> R_POSTS
    MW --> R_GEN
    MW --> R_MEDIA
    MW --> R_INT
    R_VOICE -->|"verify_ws_brand_owner()\nSec-WebSocket-Protocol"| MW

    %% Middleware verifies against Firebase Auth
    MW -->|"verify_id_token()"| FA

    %% Routers → Pipeline
    R_BRANDS --> BA
    R_PLANS --> STR
    R_GEN --> CC
    R_GEN --> RA

    %% Pipeline flow
    BA --> STR
    STR --> CC
    CC --> RA

    %% Content Creator → Sub-modules
    CC --> CP
    CC --> CB
    CC --> HE
    CC --> QG
    CC --> IPB

    %% Review Agent → Scoring
    RA --> SC
    SC --> PR

    %% Router → Support
    R_VOICE --> VC
    R_POSTS --> VID

    %% Agent → Services
    BA --> WS
    BA --> BT
    CC --> HS
    CC --> IF
    RA --> HS
    R_MEDIA --> EX

    %% Shared modules
    CL --> BA
    CL --> STR
    CL --> CC
    CL --> RA
    CO --> STR
    CO --> CC
    CO --> RA
    CO --> VC
    GU --> EX
    GU --> R_MEDIA

    %% Platform Registry
    PR --> CC
    PR --> RA
    CC --> BA_SVC
    VID --> BA_SVC
    BA_SVC -->|"Reference Images"| GCS
    R_INT --> NC
    R_INT --> EC
    NC -->|"Fernet-Encrypted<br/>OAuth Tokens"| FS
    BTS -->|"Budget Data"| FS

    %% Gemini API calls
    BA -->|"Brand Analysis<br/>(temp 0.15)"| GFlash
    STR -->|"Strategy + Frequency<br/>Google Search Grounding"| GFlash
    CC -->|"Interleaved<br/>Text + Image"| GFlash
    IF -->|"Image-Only<br/>Fallback"| GFlash
    RA -->|"engagement_scores +<br/>structural_issues"| GFlash
    VC -->|"Voice Sessions<br/>+ Calendar Context"| GLive

    %% Data stores
    R_BRANDS --> FS
    R_PLANS --> FS
    R_POSTS --> FS
    R_GEN --> FS
    R_MEDIA --> GCS
    CC -->|"Store Images"| GCS
    VID -->|"Store Video"| GCS
    EX -->|"Download Media<br/>blob.download_as_bytes"| GCS

    %% Testing
    T_MW -->|"Tests"| MW
    T_MW -->|"Tests"| MWL
    T_INT -->|"Tests"| R_INT
    T_BT -->|"Tests"| BTS
    T_BR -->|"Tests"| R_BRANDS
    T_PO -->|"Tests"| R_POSTS

    %% CI/CD
    DS -->|"Triggers"| CBuild
    CBuild -->|"Step 0: pytest<br/>Step 1: Docker Build<br/>Step 2: Push"| AR
    AR -->|"Step 3: Deploy"| APP
    TF -->|"Provisions"| FS
    TF -->|"Provisions"| GCS
    TF -->|"Provisions"| AR

    classDef browser fill:#1a1a2e,stroke:#e94560,color:#fff
    classDef cloud fill:#0f3460,stroke:#16213e,color:#fff
    classDef pipeline fill:#533483,stroke:#e94560,color:#fff
    classDef support fill:#2d4059,stroke:#ea5455,color:#fff
    classDef tools fill:#3c4043,stroke:#8ab4f8,color:#fff
    classDef gcp fill:#4285f4,stroke:#1a73e8,color:#fff
    classDef gemini fill:#1e88e5,stroke:#1565c0,color:#fff
    classDef auth fill:#ff9800,stroke:#f57c00,color:#fff
    classDef infra fill:#2e7d32,stroke:#1b5e20,color:#fff
    classDef pages fill:#1a1a2e,stroke:#8ab4f8,color:#fff
    classDef router fill:#1b5e20,stroke:#4caf50,color:#fff
    classDef middleware fill:#e65100,stroke:#ff6d00,color:#fff
    classDef shared fill:#4a148c,stroke:#7c43bd,color:#fff
    classDef scoring fill:#880e4f,stroke:#c2185b,color:#fff
    classDef submodule fill:#311b92,stroke:#7e57c2,color:#fff

    class FE browser
    class AUTH auth
    class PAGES,FE_HOOKS,WIZARD,TOUR pages
    class APP cloud
    class MW middleware
    class R_BRANDS,R_PLANS,R_POSTS,R_GEN,R_MEDIA,R_INT,R_VOICE router
    class BA,STR,CC,RA pipeline
    class CP,CB,HE,QG,IPB submodule
    class SC scoring
    class VC,VID support
    class CL,GU,CO shared
    class WS,BT,HS,EX,IF,PR,BA_SVC,NC,EC,BTS tools
    class FS,GCS,FA gcp
    class GFlash,GLive gemini
    class MWL middleware
    class TCONF,T_MW,T_INT,T_BT,T_BR,T_PO infra
    class DS,CBuild,AR,TF infra
