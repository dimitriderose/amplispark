# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit secrets.

# GCP project
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Gemini API key (server-side, set as Cloud Run env var)
GOOGLE_API_KEY=

# CORS origin for Cloud Run (your Cloud Run URL, e.g. https://amplifi-xxxxx-uc.a.run.app)
# Use * to allow all origins during development
CORS_ORIGINS=*

# Firebase config (client-side, baked into JS bundle at build time)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Notion integration (OAuth)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# Email service (Resend)
RESEND_API_KEY=

# Token encryption key for Notion OAuth tokens (Fernet, AES-128-CBC)
# Generate a key using the Fernet library
TOKEN_ENCRYPT_KEY=
